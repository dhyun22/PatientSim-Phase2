# =============================================================
# Phase 2 (Controlled Disclosure) — required environment vars
# =============================================================
# Patient + Doctor + Evaluator all use the SAME Gemini backend.
# Set this and you're done; nothing else is required for the
# Phase 2 grid.

# Gemini (Vertex AI Express Mode)
# - Generate an Express Mode API key from Google Cloud Console (Vertex AI → Express Mode).
# - Express Mode keys work with GOOGLE_GENAI_USE_VERTEXAI=False (the default).
# - Set GOOGLE_GENAI_USE_VERTEXAI=True only when using a full Vertex AI service-account/OAuth flow.
GENAI_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=False
